generator client {
  provider = "prisma-client-js"
}


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Aluno{
  id String @id @default(uuid())
  nome String
  senha String
  email String @unique
  telefone String?
  created_At DateTime @default(now())
  updated_At DateTime @updatedAt
}


model Monitor{
  id String @id @default(uuid())
  nome String
  email String
  monitorias Monitoria[] // estou dizendo que um monitor pode ter várias monitorias
}

model Monitoria {
  id String @id @default(uuid())
  nome_monitoria String
  disciplina String
  data DateTime
  hora_inicio DateTime
  hora_fim DateTime
  local String?

  monitorId String // chave estrangeira da tabela monitor
  monitor Monitor @relation(fields: [monitorId], references: [id]) // campo que relaciona com a tabela monitor e permite consultas
}